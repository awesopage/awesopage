{
  "name": "awesopage",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "boot": "pnpm install && node ./scripts/model-schema generate && pnpm list --depth -1 --recursive --json > workspace-packages.json",
    "lint": "next lint --fix",
    "compile": "tsc",
    "test": "npm run compile && cross-env NODE_OPTIONS=--experimental-vm-modules jest --config test/jest-config.js --coverage",
    "test-quick": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config test/jest-quick-config.js",
    "dev": "npm run compile && cross-env NODE_ENV=development dotenv-flow -p config -- next dev -p 4000",
    "build": "cross-env NODE_ENV=production dotenv-flow -p config -- next build",
    "build-full": "cross-env NODE_ENV=production ANALYZE=true dotenv-flow -p config -- next build",
    "clean": "node ./scripts/delete .next test-report tsconfig.tsbuildinfo workspace-cache-key.txt && pnpm --filter pkg-* run clean"
  },
  "engines": {
    "node": "16.x"
  },
  "dependencies": {
    "@prisma/client": "4.4.0",
    "axios": "1.1.2",
    "next": "12.3.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-icons": "4.4.0",
    "react-use": "17.4.0"
  },
  "devDependencies": {
    "@jest/environment": "29.1.2",
    "@jest/globals": "29.1.2",
    "@next/bundle-analyzer": "12.3.1",
    "@swc/core": "1.3.6",
    "@swc/jest": "0.2.23",
    "@testing-library/dom": "8.19.0",
    "@testing-library/react": "13.4.0",
    "@types/jest": "29.1.2",
    "@types/jest-when": "3.5.2",
    "@types/node": "16.11.64",
    "@types/react": "18.0.21",
    "@typescript-eslint/eslint-plugin": "5.39.0",
    "@typescript-eslint/parser": "5.39.0",
    "cross-env": "7.0.3",
    "cross-spawn": "7.0.3",
    "del": "6.1.1",
    "dotenv-flow": "3.2.0",
    "dotenv-flow-cli": "1.0.0",
    "eslint": "8.25.0",
    "eslint-config-next": "12.3.1",
    "eslint-config-prettier": "8.5.0",
    "eslint-plugin-file-progress": "1.3.0",
    "eslint-plugin-no-null": "1.0.2",
    "eslint-plugin-prettier": "4.2.1",
    "eslint-plugin-simple-import-sort": "8.0.0",
    "eslint-plugin-sonarjs": "0.16.0",
    "jest": "29.1.2",
    "jest-date-mock": "1.0.8",
    "jest-environment-jsdom": "29.1.2",
    "jest-extended": "3.1.0",
    "jest-junit": "14.0.1",
    "jest-stare": "2.4.1",
    "jest-when": "3.5.1",
    "prettier": "2.7.1",
    "prisma": "4.4.0",
    "react-test-renderer": "18.2.0",
    "typescript": "4.8.4"
  }
}
