{
  "name": "awesopage",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "boot": "pnpm install && pnpm list --depth -1 --recursive --json > workspace-packages.json",
    "lint": "next lint --fix",
    "compile": "tsc",
    "dev": "npm run compile && cross-env NODE_ENV=development next dev -p 4000"
  },
  "engines": {
    "node": "16.x"
  },
  "dependencies": {
    "next": "12.3.1",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/node": "16.11.64",
    "@types/react": "18.0.21",
    "@typescript-eslint/eslint-plugin": "5.39.0",
    "@typescript-eslint/parser": "5.39.0",
    "cross-env": "7.0.3",
    "eslint": "8.24.0",
    "eslint-config-next": "12.3.1",
    "eslint-config-prettier": "8.5.0",
    "eslint-plugin-file-progress": "1.3.0",
    "eslint-plugin-no-null": "1.0.2",
    "eslint-plugin-prettier": "4.2.1",
    "eslint-plugin-simple-import-sort": "8.0.0",
    "eslint-plugin-sonarjs": "0.15.0",
    "prettier": "2.7.1",
    "typescript": "4.8.4"
  }
}
